# =============================================================================
# Aerobiome Metagenomics Pipeline
# =============================================================================
# Shotgun metagenomic analysis of ultra-low biomass (ULB) air samples
# using nanopore long-read sequencing.
#
# From: Reska T, Pozdniakova S, Urban L.
#       "Air monitoring by nanopore sequencing"
#       ISME Communications (2024)
#
# Basecalling           Guppy v6.3.2 / Dorado v4.3.0 (HAC model)
# Adapter trimming      Porechop v0.2.3 / v0.2.4
# Quality filtering     NanoFilt v2.8.0
# Taxonomy              Kraken2 v2.0.7 (NCBI nt), DIAMOND BLASTx v2.1.11,
#                       Chan Zuckerberg ID (CZID)
# Read normalization    SeqKit v2.1.2
# Assembly              metaFlye v2.9.1
# Polishing             3× minimap2 v2.17 + Racon v1.5
# Binning               metaWRAP v1.3
# Bin QC                CheckM v1.2.2
# AMR / virulence       AMRFinderPlus v3.12.8, ABRicate v1.0.1 (VFDB)
# =============================================================================

import os

configfile: "config.yaml"


# ---------------------------------------------------------------------------
# Helper functions
# ---------------------------------------------------------------------------

def get_samples(sample_type=None):
    """Return sample IDs, optionally filtered by type."""
    samples = config["samples"]
    if sample_type:
        return [s for s in samples if samples[s]["type"] == sample_type]
    return list(samples.keys())


def get_negative_controls():
    """Return IDs of negative control samples for contamination filtering."""
    return [s for s in config["samples"]
            if config["samples"][s]["type"] == "negative_control"]


def get_real_samples():
    """Return IDs of actual (non-control) samples."""
    return [s for s in config["samples"]
            if config["samples"][s]["type"] != "negative_control"]


# ---------------------------------------------------------------------------
# Target rule
# ---------------------------------------------------------------------------

rule all:
    input:
        # QC-filtered reads
        expand("results/qc/{sample}_filtered.fastq.gz",
               sample=get_samples()),
        # Subsampled (normalized) reads
        expand("results/normalized/{sample}_subsampled.fastq.gz",
               sample=get_real_samples()),
        # Kraken2 taxonomy
        expand("results/taxonomy/{sample}_kraken2.report",
               sample=get_real_samples()),
        # DIAMOND BLASTx validation
        expand("results/taxonomy/{sample}_diamond.tsv",
               sample=get_real_samples()),
        # Polished assemblies
        expand("results/assembly/{sample}/assembly_polished.fasta",
               sample=get_real_samples()),
        # metaWRAP bins
        expand("results/binning/{sample}/metawrap_bins/",
               sample=get_real_samples()),
        # CheckM bin quality
        expand("results/binning/{sample}/checkm/",
               sample=get_real_samples()),
        # AMR results (reads + contigs + bins)
        expand("results/amr/{sample}_amrfinderplus.tsv",
               sample=get_real_samples()),
        expand("results/amr/{sample}_abricate.tsv",
               sample=get_real_samples()),
        # Virulence results
        expand("results/virulence/{sample}_vfdb.tsv",
               sample=get_real_samples()),


# ===========================================================================
# STEP 1: BASECALLING & READ PROCESSING
# ===========================================================================

rule basecall_dorado:
    """Basecall raw FAST5/POD5 signals with Dorado v4.3.0 (HAC model).

    Guppy v6.3.2 was used for the greenhouse and natural environment
    datasets; Dorado v4.3.0 (HAC) for the urban campaign in Barcelona.
    """
    input:
        pod5=lambda wc: config["samples"][wc.sample]["raw_data"]
    output:
        bam="results/basecalling/{sample}_calls.bam"
    params:
        model=config["basecalling"]["model"]
    threads: 8
    log:
        "logs/basecalling/{sample}.log"
    shell:
        """
        dorado basecaller \
            {params.model} \
            {input.pod5} \
            > {output.bam} \
            2> {log}
        """


rule demux_and_trim:
    """Demultiplex and trim adapters with Porechop v0.2.4."""
    input:
        fastq=lambda wc: config["samples"][wc.sample]["fastq"]
    output:
        fastq="results/trimmed/{sample}_trimmed.fastq.gz"
    threads: 4
    log:
        "logs/porechop/{sample}.log"
    shell:
        """
        porechop \
            -i {input.fastq} \
            -o {output.fastq} \
            --threads {threads} \
            2> {log}
        """


rule quality_filter:
    """Quality-filter reads with NanoFilt v2.8.0.

    Parameters: Q ≥ 8, read length ≥ 100 bp.
    ULB air samples yield short fragments, so we use a permissive
    minimum length to retain as much usable data as possible.
    """
    input:
        fastq="results/trimmed/{sample}_trimmed.fastq.gz"
    output:
        fastq="results/qc/{sample}_filtered.fastq.gz"
    params:
        min_quality=config["qc"]["min_quality"],      # 8
        min_length=config["qc"]["min_length"]          # 100
    log:
        "logs/nanofilt/{sample}.log"
    shell:
        """
        gunzip -c {input.fastq} | \
        NanoFilt \
            -q {params.min_quality} \
            -l {params.min_length} \
            2> {log} | \
        gzip > {output.fastq}
        """


# ===========================================================================
# STEP 2: READ NORMALIZATION
# ===========================================================================

rule subsample_reads:
    """Normalize read depth with SeqKit v2.1.2.

    Subsampling thresholds are phase-specific:
      - 1h greenhouse:       5,000 reads
      - 3h greenhouse:      15,000 reads
      - Natural environment: 70,000 reads
      - Urban environment:   30,000 reads
    """
    input:
        fastq="results/qc/{sample}_filtered.fastq.gz"
    output:
        fastq="results/normalized/{sample}_subsampled.fastq.gz"
    params:
        n_reads=lambda wc: config["samples"][wc.sample]["subsample_reads"]
    log:
        "logs/seqkit/{sample}.log"
    shell:
        """
        seqkit sample \
            -n {params.n_reads} \
            -s 42 \
            {input.fastq} \
            -o {output.fastq} \
            2> {log}
        """


# ===========================================================================
# STEP 3: TAXONOMIC CLASSIFICATION
# ===========================================================================

rule kraken2_classify:
    """Classify reads with Kraken2 v2.0.7 against NCBI nt database."""
    input:
        fastq="results/normalized/{sample}_subsampled.fastq.gz",
        db=config["references"]["kraken2_db"]
    output:
        report="results/taxonomy/{sample}_kraken2.report",
        output="results/taxonomy/{sample}_kraken2.output"
    threads: 8
    log:
        "logs/kraken2/{sample}.log"
    shell:
        """
        kraken2 \
            --db {input.db} \
            --threads {threads} \
            --report {output.report} \
            --output {output.output} \
            --gzip-compressed \
            {input.fastq} \
            2> {log}
        """


rule diamond_blastx:
    """Validate taxonomy with DIAMOND BLASTx v2.1.11 against NCBI nr.

    Protein-level validation complements nucleotide-based Kraken2
    classification, providing an independent confirmation of species
    assignments — especially important for ULB samples.
    """
    input:
        fastq="results/normalized/{sample}_subsampled.fastq.gz",
        db=config["references"]["diamond_nr_db"]
    output:
        tsv="results/taxonomy/{sample}_diamond.tsv"
    threads: 8
    log:
        "logs/diamond/{sample}.log"
    shell:
        """
        seqkit fq2fa {input.fastq} | \
        diamond blastx \
            --db {input.db} \
            --out {output.tsv} \
            --outfmt 6 qseqid sseqid pident length evalue bitscore stitle staxids \
            --threads {threads} \
            --sensitive \
            2> {log}
        """


# ===========================================================================
# STEP 4: DE NOVO ASSEMBLY, POLISHING & BINNING
# ===========================================================================

rule metaflye_assembly:
    """Assemble reads with metaFlye v2.9.1.

    For the urban dataset, reads from all samples within a location
    were pooled prior to assembly.
    """
    input:
        fastq="results/qc/{sample}_filtered.fastq.gz"
    output:
        assembly="results/assembly/{sample}/assembly.fasta",
        info="results/assembly/{sample}/assembly_info.txt"
    params:
        outdir="results/assembly/{sample}"
    threads: 16
    log:
        "logs/metaflye/{sample}.log"
    shell:
        """
        flye \
            --nano-hq {input.fastq} \
            --out-dir {params.outdir} \
            --meta \
            --threads {threads} \
            2> {log}
        """


rule polish_racon:
    """Polish assembly with 3 iterative rounds of minimap2 v2.17 + Racon v1.5.

    At each round, reads are re-mapped to the current consensus
    before correction.
    """
    input:
        reads="results/qc/{sample}_filtered.fastq.gz",
        assembly="results/assembly/{sample}/assembly.fasta"
    output:
        polished="results/assembly/{sample}/assembly_polished.fasta"
    threads: 8
    log:
        "logs/racon/{sample}.log"
    shell:
        """
        cp {input.assembly} {output.polished}.round0.fasta

        for round in 1 2 3; do
            prev=$((round - 1))

            minimap2 -t {threads} -x map-ont \
                {output.polished}.round${{prev}}.fasta \
                {input.reads} \
                > results/assembly/{wildcards.sample}/overlap_r${{round}}.paf \
                2>> {log}

            racon -t {threads} \
                {input.reads} \
                results/assembly/{wildcards.sample}/overlap_r${{round}}.paf \
                {output.polished}.round${{prev}}.fasta \
                > {output.polished}.round${{round}}.fasta \
                2>> {log}
        done

        mv {output.polished}.round3.fasta {output.polished}
        rm -f {output.polished}.round*.fasta \
              results/assembly/{wildcards.sample}/overlap_r*.paf
        """


rule metawrap_binning:
    """Bin contigs with metaWRAP v1.3."""
    input:
        assembly="results/assembly/{sample}/assembly_polished.fasta",
        reads="results/qc/{sample}_filtered.fastq.gz"
    output:
        bindir=directory("results/binning/{sample}/metawrap_bins/")
    params:
        outdir="results/binning/{sample}"
    threads: 8
    log:
        "logs/metawrap/{sample}.log"
    shell:
        """
        metawrap binning \
            -o {params.outdir} \
            -t {threads} \
            -a {input.assembly} \
            --metabat2 --maxbin2 --concoct \
            {input.reads} \
            2> {log}
        """


rule checkm_quality:
    """Assess bin quality with CheckM v1.2.2.

    Relaxed thresholds for ULB samples:
      - Completeness ≥ 30%
      - Contamination ≤ 10%
    """
    input:
        bins="results/binning/{sample}/metawrap_bins/"
    output:
        outdir=directory("results/binning/{sample}/checkm/")
    threads: 8
    log:
        "logs/checkm/{sample}.log"
    shell:
        """
        checkm lineage_wf \
            {input.bins} \
            {output.outdir} \
            -t {threads} \
            -x fa \
            2> {log}
        """


# ===========================================================================
# STEP 5: FUNCTIONAL ANNOTATION (AMR, VIRULENCE)
# ===========================================================================

rule convert_reads_to_fasta:
    """Convert FASTQ to FASTA with SeqKit v2.8.2 for read-level annotation."""
    input:
        fastq="results/qc/{sample}_filtered.fastq.gz"
    output:
        fasta="results/qc/{sample}_filtered.fasta"
    shell:
        "seqkit fq2fa {input.fastq} > {output.fasta}"


rule amrfinderplus:
    """Detect AMR and virulence genes with AMRFinderPlus v3.12.8.

    Applied to both reads and contigs.
    """
    input:
        reads_fasta="results/qc/{sample}_filtered.fasta",
        contigs="results/assembly/{sample}/assembly_polished.fasta"
    output:
        reads_amr="results/amr/{sample}_amrfinderplus_reads.tsv",
        contigs_amr="results/amr/{sample}_amrfinderplus.tsv"
    threads: 4
    log:
        "logs/amrfinderplus/{sample}.log"
    shell:
        """
        amrfinder \
            --nucleotide {input.reads_fasta} \
            --output {output.reads_amr} \
            --threads {threads} \
            2> {log}

        amrfinder \
            --nucleotide {input.contigs} \
            --output {output.contigs_amr} \
            --threads {threads} \
            2>> {log}
        """


rule abricate_amr:
    """Screen for AMR genes with ABRicate v1.0.1."""
    input:
        contigs="results/assembly/{sample}/assembly_polished.fasta"
    output:
        hits="results/amr/{sample}_abricate.tsv"
    log:
        "logs/abricate/{sample}.log"
    shell:
        """
        abricate \
            --db ncbi \
            {input.contigs} \
            > {output.hits} \
            2> {log}
        """


rule abricate_virulence:
    """Screen for virulence factors with ABRicate v1.0.1 against VFDB."""
    input:
        contigs="results/assembly/{sample}/assembly_polished.fasta"
    output:
        hits="results/virulence/{sample}_vfdb.tsv"
    log:
        "logs/abricate_vfdb/{sample}.log"
    shell:
        """
        abricate \
            --db vfdb \
            {input.contigs} \
            > {output.hits} \
            2> {log}
        """


# ===========================================================================
# STEP 6: COMMUNITY ANALYSIS
# ===========================================================================

rule beta_diversity:
    """Compute Bray-Curtis dissimilarity and PCoA at genus level.

    Rarefaction curves generated from 5k–70k reads.
    """
    input:
        reports=expand("results/taxonomy/{sample}_kraken2.report",
                       sample=get_real_samples())
    output:
        pcoa="results/community/pcoa_coordinates.tsv",
        bray_curtis="results/community/bray_curtis_matrix.tsv",
        rarefaction="results/community/rarefaction_curves.png"
    params:
        samples=get_real_samples()
    log:
        "logs/community_analysis.log"
    script:
        "scripts/community_analysis.py"
