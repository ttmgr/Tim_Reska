rule community_analysis:
    """Bray-Curtis dissimilarity, PCoA, and rarefaction at genus level.

    Rarefaction at 87k reads.
    """
    input:
        reports=expand("results/metagenomics/taxonomy/{sample}_kraken2.report",
                       sample=get_samples())
    output:
        bray_curtis="results/community/bray_curtis_matrix.tsv",
        pcoa="results/community/pcoa_coordinates.tsv"
    params:
        samples=get_samples()
    log:
        "logs/community_analysis.log"
    script:
        "scripts/community_analysis.py"
