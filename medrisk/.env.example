# Copy to .env and fill in your tokens. Never commit .env to version control.

# Zenodo personal access token (for higher rate limits and controlled records)
ZENODO_TOKEN=

# Socrata App Token (for CDC PLACES and data.gov Socrata APIs)
SOCRATA_APP_TOKEN=

# UK Biobank: path to locally downloaded application data
UKB_DATA_PATH=

# BioLINCC: path to locally downloaded teaching/controlled datasets
BIOLINCC_DATA_PATH=

# Override default config/cache locations if needed
# MEDRISK_FETCH_CONFIG_DIR=configs
# MEDRISK_FETCH_CACHE_DIR=.cache/medrisk_fetch
# MEDRISK_FETCH_LOG_LEVEL=INFO
